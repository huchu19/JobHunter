// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- Auth.js (next-auth v5) models -------------------------------------------
// User/Account/Session/VerificationToken are the schema the @auth/prisma-adapter
// expects. A User owns all their app data (board, profile, settings, ratings).
// `apiToken` is a long-lived personal token the Chrome extension sends as a
// bearer credential, since cookie sessions don't flow cross-origin from job
// boards (see app/lib/auth.ts).
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  apiToken      String?   @unique

  accounts     Account[]
  sessions     Session[]
  applications Application[]
  ratings      Rating[]
  profile      Profile?
  settings     NotificationSettings?

  createdAt DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Application {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company         String
  role            String
  url             String?
  location        String?
  locationType    String   @default("london")
  jobType         String   @default("grad")
  status          String   @default("wishlist")
  appliedAt       DateTime?
  notes           String?
  salary          String?
  source          String?
  sponsorVerified Boolean  @default(false)

  // Prioritisation
  priority        Int       @default(0) // 0 = unset, 1..5 interest rating

  // Key dates
  deadline        DateTime? // application close date
  followUpDate    DateTime? // next nudge/chase date

  // Per-stage timestamps (auto-set on status transition)
  interviewAt     DateTime?
  offerAt         DateTime?
  rejectedAt      DateTime?

  // Decision / outcome
  rejectedReason  String? // e.g. "ghosted" | "position-filled" | "after-interview" | free text

  // Contact
  contactName     String?
  contactEmail    String?

  // Richer detail
  jobDescription  String? // the pasted job description

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  activities      Activity[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// Timeline of events for an application: auto-logged status changes plus
// user-added interview rounds, notes, and follow-ups. Powers the detail-view
// activity timeline. Needs N rows per application, hence a related model.
model Activity {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  type          String // "created" | "status_change" | "interview" | "note" | "follow_up"
  fromStatus    String?
  toStatus      String?
  title         String? // e.g. "Phone screen", "Technical round 2"
  notes         String?
  occurredAt    DateTime    @default(now()) // user-settable for scheduled interviews
  createdAt     DateTime    @default(now())

  @@index([applicationId])
  @@index([occurredAt])
}

// Per-user notification preferences (one row per user, keyed by userId).
// Email settings are stored even when no email transport is configured —
// delivery is env-gated behind RESEND_API_KEY and no-ops without it.
model NotificationSettings {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Email
  emailEnabled      Boolean @default(false)
  emailAddress      String?
  weeklyDigest      Boolean @default(true)
  followUpReminders Boolean @default(true)
  interviewAlerts   Boolean @default(true)
  offerCelebration  Boolean @default(true)

  // Browser
  browserEnabled Boolean @default(false)

  // Sponsor matching (Milestone 10): JSON array of company names from the
  // last match run, so the daily job can email "N new sponsors matched".
  matchSnapshot  String?
  lastMatchRunAt DateTime?

  updatedAt DateTime @updatedAt
}

// A researched company: created lazily the first time it is rated. Aggregated
// ratings power the /companies/[name] research page. Name matches the
// Application.company string (case-insensitive lookup is done in the route).
model Company {
  id        String   @id @default(cuid())
  name      String   @unique
  ratings   Rating[]
  createdAt DateTime @default(now())
}

// Cached resolution of a registered sponsor name → its real careers page.
// The gov.uk register only gives a legal name (e.g. "MONZO BANK LIMITED") with
// no website, so we resolve the actual careers/ATS URL once (deterministic
// domain guess, enriched by an AI web search when ANTHROPIC_API_KEY is set) and
// store it here. Negative results are cached too (status "unresolved") so we
// never re-burn a web search on a company we already failed to find.
model CompanyCareers {
  id          String   @id @default(cuid())
  name        String   @unique // registered name — the lookup key
  careersUrl  String? // resolved careers / ATS listings URL
  homepageUrl String? // resolved homepage (fallback)
  atsType     String? // "greenhouse" | "lever" | "ashby" | "workday" | "smartrecruiters" | "other" | null
  atsToken    String? // ATS board token/slug for the listings API (e.g. greenhouse board id)
  confidence  String? // "high" | "low"
  status      String   @default("ok") // "ok" | "unresolved"
  resolvedAt  DateTime @default(now())

  @@index([name])
}

// A single 1–5-star rating of a company in one category
// ("work-culture" | "sponsorship" | "responsiveness"), with an optional
// anonymous comment.
model Rating {
  id        String   @id @default(cuid())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int // 1-5 stars
  comment   String?
  category  String // "work-culture" | "sponsorship" | "responsiveness"
  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([userId])
}

// Per-user reusable application profile. Holds answers to common job-application
// questions, mostly auto-extracted from an uploaded resume (Anthropic or Gemini).
// Surfaced on /profile with copy-to-clipboard for fast pasting into external forms.
model Profile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Contact
  fullName     String?
  email        String?
  phone        String?
  location     String?
  linkedinUrl  String?
  githubUrl    String?
  portfolioUrl String?
  websiteUrl   String?

  // Common application answers
  workAuthorization String?
  needsSponsorship  Boolean?
  rightToWork       String?
  noticePeriod      String?
  salaryExpectation String?
  earliestStart     String?
  yearsExperience   String?
  currentTitle      String?

  // Free-text blocks
  summary String?
  skills  String?

  // Structured entries — stored as JSON arrays so each item can be copy-pasted
  // into individual ATS fields without manual splitting.
  // educationEntries:  [{institution, degree, field, grade, startYear, endYear}]
  // experienceEntries: [{company, title, startDate, endDate, current, location, description}]
  // certifications:    [{name, issuer, date, credentialUrl}]
  // languages:         [{language, proficiency}]
  // projects:          [{name, description, url, technologies}]
  educationEntries   String? // JSON
  experienceEntries  String? // JSON
  certifications     String? // JSON
  languages          String? // JSON
  projects           String? // JSON

  // Misc quick-fill answers
  highestQualification String? // "Bachelor's" | "Master's" | "PhD" | etc.
  willingToRelocate    String? // "yes" | "no" | "maybe"
  drivingLicence       String? // "yes" | "no"
  securityClearance    String? // "none" | "DBS" | "SC" | "DV"

  // Resume bookkeeping
  resumeText     String?
  resumeFileName String?
  resumeParsedAt DateTime?

  // The original uploaded file, kept so the user can preview / download / replace
  // it on /profile. `resumeData` is the file bytes base64-encoded (PDF or DOCX);
  // `resumeMimeType` drives how it's served and whether it can be previewed inline
  // (PDF yes, DOCX download-only — browsers can't render .docx).
  resumeData     String?
  resumeMimeType String?

  updatedAt DateTime @updatedAt
}
