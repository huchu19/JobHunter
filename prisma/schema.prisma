// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Application {
  id              String   @id @default(cuid())
  company         String
  role            String
  url             String?
  location        String?
  locationType    String   @default("london")
  jobType         String   @default("grad")
  status          String   @default("wishlist")
  appliedAt       DateTime?
  notes           String?
  salary          String?
  source          String?
  sponsorVerified Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

// Single-row reusable application profile. Holds answers to common job-application
// questions, mostly auto-extracted from an uploaded resume via the Claude API.
// Surfaced on /profile with copy-to-clipboard for fast pasting into external forms.
model Profile {
  id String @id @default("singleton")

  // Contact
  fullName     String?
  email        String?
  phone        String?
  location     String?
  linkedinUrl  String?
  githubUrl    String?
  portfolioUrl String?
  websiteUrl   String?

  // Common application answers
  workAuthorization String?
  needsSponsorship  Boolean?
  rightToWork       String?
  noticePeriod      String?
  salaryExpectation String?
  earliestStart     String?
  yearsExperience   String?
  currentTitle      String?

  // Free-text blocks frequently re-pasted into applications
  summary     String?
  skills      String?
  education   String?
  workHistory String?

  // Resume bookkeeping
  resumeText     String?
  resumeFileName String?
  resumeParsedAt DateTime?

  updatedAt DateTime @updatedAt
}
